# CookAI Configuration

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cookai
DB_USER=root
DB_PASS=password

# Base URL
BASE_URL=http://localhost
BASE_PATH=/

# Payment
PAYMENT_LIVE_MODE=false
PLAN_MONTHLY_PRICE=299
PLAN_YEARLY_PRICE=2990
RENEW_NOTIFY_DAYS=3

# YandexGPT
YANDEX_FOLDER_ID=your-folder-id
YANDEX_API_KEY=your-api-key

# Admin Emails (comma-separated)
ADMIN_EMAILS=admin@cookai.ru,demo@cookai.ru

# Debug Mode
APP_DEBUG=false
